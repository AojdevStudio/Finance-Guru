# API Keys (DO NOT COMMIT ACTUAL KEYS)
# See docs/api-keys.md for detailed acquisition instructions

# Market Data APIs (all optional - yfinance works without keys)
FINNHUB_API_KEY=your_finnhub_api_key_here
ITC_API_KEY=your_itc_api_key_here

# Optional: OpenAI (for specific agent tasks)
OPENAI_API_KEY=your_openai_api_key_here

# Database
DATABASE_URL=sqlite:///family_office.db

# Email Settings (for reports)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your_email@example.com
EMAIL_PASSWORD=your_app_password_here

# Notification Settings
SLACK_WEBHOOK_URL=your_slack_webhook_here

# Portfolio Settings
DEFAULT_RISK_TOLERANCE=aggressive
REBALANCE_THRESHOLD=0.05
TAX_RATE=0.25

# Finance Guru Personal Strategy Inputs
# Copy this file to .env and fill in real values locally. Do not commit .env.
FG_PORTFOLIO_STRUCTURE=your_portfolio_structure_here
FG_W2_MONTHLY_INCOME=your_w2_monthly_income_here
FG_BUSINESS_INCOME_MONTHLY=your_business_income_monthly_here
FG_ANNUAL_DIVIDEND_TARGET=your_annual_dividend_target_here
FG_DIVIDEND_TARGET_MONTHS=your_target_month_count_here
FG_MONTE_CARLO_PROBABILITY=your_model_probability_here
FG_STRATEGY_START_DATE=YYYY-MM-DD
FG_HEDGE_BUDGET_MONTHLY=your_hedge_budget_here
FG_GOOGL_DEPLOYMENT_MONTHLY=your_googl_deployment_here

# Margin Management Inputs
FG_MARGIN_INTEREST_RATE=your_margin_rate_percent_here
FG_MARGIN_INTEREST_RATE_DECIMAL=your_margin_rate_decimal_here
FG_MARGIN_JUMP_ALERT_THRESHOLD=your_margin_jump_threshold_here
FG_CURRENT_MONTHLY_DRAW=your_current_monthly_draw_here
FG_MONTH6_DRAW_TARGET=your_month_6_draw_target_here
FG_MONTH12_DRAW_TARGET=your_month_12_draw_target_here
FG_MONTH18_DRAW_TARGET=your_month_18_draw_target_here
FG_BUSINESS_INJECTION_RED=your_red_alert_injection_amount_here
FG_BUSINESS_INJECTION_CRITICAL=your_critical_injection_amount_here
FG_BUSINESS_BACKSTOP_PROBABILITY=your_business_backstop_probability_here

# Optional local example values used by docs/skills examples
FG_PORTFOLIO_BASELINE_VALUE=your_portfolio_value_here
FG_PORTFOLIO_BASELINE_VALUE_RAW=your_portfolio_value_raw_here
FG_PORTFOLIO_DAY_CHANGE_RAW=your_portfolio_day_change_raw_here
FG_MARGIN_BUYING_POWER_RAW=your_margin_buying_power_raw_here
FG_MARGIN_BUYING_POWER_DAY_CHANGE_RAW=your_margin_buying_power_day_change_raw_here
FG_MARGIN_BASELINE_BALANCE=your_margin_balance_here
FG_MARGIN_BASELINE_BALANCE_RAW=your_margin_balance_raw_here
FG_MARGIN_DAY_CHANGE=your_margin_day_change_here
FG_MARGIN_DAY_CHANGE_RAW=your_margin_day_change_raw_here
FG_MARGIN_INTEREST_ACCRUED_THIS_MONTH_RAW=your_margin_interest_accrued_raw_here
FG_MARGIN_MONTHLY_INTEREST_COST=your_monthly_interest_cost_here
FG_MARGIN_ANNUAL_INTEREST_COST=your_annual_interest_cost_here
FG_DIVIDEND_MONTHLY_INCOME=your_monthly_dividend_income_here
FG_DIVIDEND_COVERAGE_RATIO=your_dividend_coverage_ratio_here
FG_PORTFOLIO_MARGIN_RATIO=your_portfolio_margin_ratio_here
FG_MARGIN_JUMP_EXAMPLE_CURRENT=your_margin_jump_example_current_here
FG_MARGIN_JUMP_EXAMPLE_DIFF=your_margin_jump_example_diff_here
FG_MARGIN_EXAMPLE_DATE=YYYY-MM-DD
FG_MONTH6_DIVIDEND_MINIMUM=your_month_6_dividend_minimum_here
FG_MONTH12_DIVIDEND_TARGET=your_month_12_dividend_target_here
FG_MONTH18_DIVIDEND_TARGET=your_month_18_dividend_target_here
FG_MONTH6_PROJECTED_PORTFOLIO=your_month_6_projected_portfolio_here
FG_MONTH6_PROJECTED_MARGIN=your_month_6_projected_margin_here
FG_MONTH6_PROJECTED_RATIO=your_month_6_projected_ratio_here
FG_MONTH6_PROJECTED_MONTHLY_INTEREST=your_month_6_projected_interest_here
FG_MONTH6_PROJECTED_COVERAGE=your_month_6_projected_coverage_here
FG_MONTH15_PROJECTED_PORTFOLIO=your_month_15_projected_portfolio_here
FG_MONTH15_PROJECTED_MARGIN=your_month_15_projected_margin_here
FG_MONTH15_PROJECTED_RATIO=your_month_15_projected_ratio_here
